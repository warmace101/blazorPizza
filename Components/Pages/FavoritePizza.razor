@page "/favorite-pizza/{favorite}"
@page "/favorite-pizza/{favorite?}"
@rendermode InteractiveServer

<PageTitle>Favorite Pizza - @Favorite</PageTitle>

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card">
                <div class="card-header bg-warning text-dark">
                    <h2>🍕 Your Favorite Pizza</h2>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <h4>Optional Route Parameters Example</h4>
                        <p>This page demonstrates optional route parameters using <code>{favorite?}</code></p>
                        <ul>
                            <li><code>@@page "/favorite-pizza/{favorite}"</code> - Required parameter</li>
                            <li><code>@@page "/favorite-pizza/{favorite?}"</code> - Optional parameter</li>
                        </ul>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <h3>Current Selection</h3>
                            <div class="card bg-light">
                                <div class="card-body text-center">
                                    <h4 class="text-primary">@Favorite</h4>
                                    <p class="text-muted">Your current favorite pizza</p>
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-md-6">
                            <h3>Route Information</h3>
                            <dl>
                                <dt>Parameter Value:</dt>
                                <dd><code>@Favorite</code></dd>
                                
                                <dt>Parameter Source:</dt>
                                <dd>@(WasDefaultSet ? "Default value (OnInitialized)" : "URL route parameter")</dd>
                                
                                <dt>Route Pattern:</dt>
                                <dd><code>/favorite-pizza/{favorite?}</code></dd>
                            </dl>
                        </div>
                    </div>
                    
                    <div class="mt-4">
                        <h4>Test Different URLs:</h4>
                        <div class="row">
                            <div class="col-md-4">
                                <a href="/favorite-pizza/margherita" class="btn btn-outline-primary btn-sm w-100">
                                    /favorite-pizza/margherita
                                </a>
                            </div>
                            <div class="col-md-4">
                                <a href="/favorite-pizza/hawaiian" class="btn btn-outline-success btn-sm w-100">
                                    /favorite-pizza/hawaiian
                                </a>
                            </div>
                            <div class="col-md-4">
                                <a href="/favorite-pizza" class="btn btn-outline-warning btn-sm w-100">
                                    /favorite-pizza (no param)
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string Favorite { get; set; } = string.Empty;
    
    private bool WasDefaultSet { get; set; }
    
    protected override void OnInitialized()
    {
        // Set default value for optional parameter as shown in the module
        if (string.IsNullOrEmpty(Favorite))
        {
            Favorite = "Fiorentina";
            WasDefaultSet = true;
        }
    }
}