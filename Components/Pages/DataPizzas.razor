@page "/data-pizzas"
@using BlazingPizza.Data
@inject PizzaService PizzaSvc
@rendermode InteractiveServer

<PageTitle>Pizza Data Access Demo</PageTitle>

<div class="container">
    <h1>🍕 Choose Your Pizza</h1>
    <p class="text-muted">Demonstrating data access patterns in Blazor components</p>

    @* Conditional rendering - show loading message while data loads *@
    @if (todaysPizzas == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3 text-info">🔍 We're finding out what pizzas are available today...</p>
        </div>
    }
    else if (!todaysPizzas.Any())
    {
        <div class="alert alert-warning">
            <h4>😔 No Pizzas Available</h4>
            <p>Sorry, we don't have any pizzas available right now. Please check back later!</p>
        </div>
    }
    else
    {
        @* Data controls section *@
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">🎛️ Data Controls</h5>
                        <div class="d-flex gap-2 flex-wrap">
                            <button class="btn btn-outline-primary btn-sm" @onclick="LoadAllPizzas">
                                🍕 All Pizzas (@allPizzasCount)
                            </button>
                            <button class="btn btn-outline-success btn-sm" @onclick="LoadVegetarianPizzas">
                                🥬 Vegetarian (@vegPizzasCount)
                            </button>
                            <button class="btn btn-outline-info btn-sm" @onclick="LoadVeganPizzas">
                                🌱 Vegan (@veganPizzasCount)
                            </button>
                            <button class="btn btn-outline-warning btn-sm" @onclick="LoadTopRated">
                                ⭐ Top Rated
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">🔍 Search</h5>
                        <div class="input-group">
                            <input class="form-control" @bind="searchTerm" @bind:event="oninput" 
                                   placeholder="Search pizzas..." />
                            <button class="btn btn-outline-secondary" @onclick="SearchPizzas">Search</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* Loading indicator for operations *@
        @if (isLoading)
        {
            <div class="alert alert-info">
                <div class="d-flex align-items-center">
                    <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                    Loading pizzas...
                </div>
            </div>
        }

        @* Display current data info *@
        <div class="row mb-3">
            <div class="col-12">
                <div class="bg-light p-3 rounded">
                    <strong>📊 Current View:</strong> 
                    <span class="badge bg-primary ms-2">@todaysPizzas.Length pizza(s) loaded</span>
                    <span class="badge bg-success ms-1">@todaysPizzas.Count(p => p.IsAvailable) available</span>
                    <span class="badge bg-secondary ms-1">@todaysPizzas.Count(p => !p.IsAvailable) sold out</span>
                    @if (!string.IsNullOrEmpty(currentFilter))
                    {
                        <span class="badge bg-info ms-1">Filter: @currentFilter</span>
                    }
                </div>
            </div>
        </div>

        @* Pizza data table - following tutorial example *@
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Pizza Name</th>
                        <th>Description</th>
                        <th>Category</th>
                        <th>Vegetarian?</th>
                        <th>Vegan?</th>
                        <th>Rating</th>
                        <th>Price</th>
                        <th>Status</th>
                        <th>Ingredients</th>
                    </tr>
                </thead>
                <tbody>
                    @* Using @foreach to iterate through the collection *@
                    @foreach (var pizza in todaysPizzas)
                    {
                        <tr class="@(pizza.IsAvailable ? "" : "table-secondary")">
                            <td>
                                <strong>@pizza.Name</strong>
                                @if (pizza.Rating == 5)
                                {
                                    <span class="badge bg-warning text-dark ms-1">⭐ Top Rated</span>
                                }
                            </td>
                            <td>@pizza.Description</td>
                            <td>
                                <span class="badge bg-@GetCategoryBadgeColor(pizza.Category)">
                                    @pizza.Category
                                </span>
                            </td>
                            <td>
                                @if (pizza.Vegetarian)
                                {
                                    <span class="text-success">✅ Yes</span>
                                }
                                else
                                {
                                    <span class="text-muted">❌ No</span>
                                }
                            </td>
                            <td>
                                @if (pizza.Vegan)
                                {
                                    <span class="text-success">🌱 Yes</span>
                                }
                                else
                                {
                                    <span class="text-muted">❌ No</span>
                                }
                            </td>
                            <td>
                                <div class="text-warning">
                                    @for (int i = 0; i < pizza.Rating; i++)
                                    {
                                        <span>⭐</span>
                                    }
                                    @for (int i = pizza.Rating; i < 5; i++)
                                    {
                                        <span class="text-muted">☆</span>
                                    }
                                </div>
                                <small class="text-muted">(@pizza.Rating/5)</small>
                            </td>
                            <td>
                                <strong class="text-success">@pizza.Price.ToString("C", System.Globalization.CultureInfo.CreateSpecificCulture("en-US"))</strong>
                            </td>
                            <td>
                                @if (pizza.IsAvailable)
                                {
                                    <span class="badge bg-success">✅ Available</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">❌ Sold Out</span>
                                }
                            </td>
                            <td>
                                <div class="ingredients-container">
                                    @foreach (var ingredient in pizza.Ingredients.Take(3))
                                    {
                                        <span class="badge bg-light text-dark me-1 mb-1">@ingredient</span>
                                    }
                                    @if (pizza.Ingredients.Count > 3)
                                    {
                                        <small class="text-muted">+@(pizza.Ingredients.Count - 3) more</small>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* Summary statistics *@
        <div class="row mt-4">
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h5 class="card-title text-primary">@todaysPizzas.Length</h5>
                        <p class="card-text">Total Pizzas Loaded</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h5 class="card-title text-success">@todaysPizzas.Average(p => (double)p.Price).ToString("C", System.Globalization.CultureInfo.CreateSpecificCulture("en-US"))</h5>
                        <p class="card-text">Average Price</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h5 class="card-title text-warning">@todaysPizzas.Average(p => p.Rating).ToString("F1")</h5>
                        <p class="card-text">Average Rating</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h5 class="card-title text-info">@todaysPizzas.Count(p => p.Vegetarian)</h5>
                        <p class="card-text">Vegetarian Options</p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    // Private field to store the data
    private BlazingPizza.Data.Pizza[]? todaysPizzas;
    private bool isLoading = false;
    private string searchTerm = "";
    private string currentFilter = "";
    
    // Stats for button labels
    private int allPizzasCount = 0;
    private int vegPizzasCount = 0;
    private int veganPizzasCount = 0;

    // Override OnInitializedAsync to load data when component initializes
    protected override async Task OnInitializedAsync()
    {
        await LoadAllPizzas();
        await LoadStats();
    }

    // Method to load all pizzas - following tutorial pattern
    private async Task LoadAllPizzas()
    {
        isLoading = true;
        currentFilter = "";
        
        try 
        {
            // Call the service using await - following tutorial pattern
            todaysPizzas = await PizzaSvc.GetPizzasAsync();
        }
        finally
        {
            isLoading = false;
        }
    }

    // Load stats for button labels  
    private async Task LoadStats()
    {
        var allPizzas = await PizzaSvc.GetPizzasAsync();
        allPizzasCount = allPizzas.Length;
        
        var vegPizzas = await PizzaSvc.GetVegetarianPizzasAsync();
        vegPizzasCount = vegPizzas.Length;
        
        var veganPizzas = await PizzaSvc.GetVeganPizzasAsync();
        veganPizzasCount = veganPizzas.Length;
    }

    // Method to load vegetarian pizzas
    private async Task LoadVegetarianPizzas()
    {
        isLoading = true;
        currentFilter = "Vegetarian Only";
        
        try
        {
            todaysPizzas = await PizzaSvc.GetVegetarianPizzasAsync();
        }
        finally
        {
            isLoading = false;
        }
    }

    // Method to load vegan pizzas  
    private async Task LoadVeganPizzas()
    {
        isLoading = true;
        currentFilter = "Vegan Only";
        
        try
        {
            todaysPizzas = await PizzaSvc.GetVeganPizzasAsync();
        }
        finally
        {
            isLoading = false;
        }
    }

    // Method to load top rated pizzas
    private async Task LoadTopRated()
    {
        isLoading = true;
        currentFilter = "Top Rated";
        
        try
        {
            todaysPizzas = await PizzaSvc.GetTopRatedPizzasAsync();
        }
        finally
        {
            isLoading = false;
        }
    }

    // Method to search pizzas
    private async Task SearchPizzas()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            await LoadAllPizzas();
            return;
        }

        isLoading = true;
        currentFilter = $"Search: '{searchTerm}'";
        
        try
        {
            todaysPizzas = await PizzaSvc.SearchPizzasAsync(searchTerm);
        }
        finally
        {
            isLoading = false;
        }
    }

    // Helper method for category badge colors
    private string GetCategoryBadgeColor(string category)
    {
        return category switch
        {
            "Classic" => "primary",
            "Meat" => "danger", 
            "Vegetarian" => "success",
            "Vegan" => "info",
            "Gourmet" => "warning",
            _ => "secondary"
        };
    }
}