@page "/database-demo"
@using BlazingPizza.Data
@inject HttpClient HttpClient
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Database Demo - Entity Framework</PageTitle>

<div class="container">
    <h1>🗃️ Database Access Demo</h1>
    <p class="text-muted">This page demonstrates Entity Framework Core with SQLite database access following the exercise patterns.</p>

    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5>📋 Exercise Implementation</h5>
                </div>
                <div class="card-body">
                    <dl>
                        <dt>Database Context:</dt>
                        <dd><code>PizzaStoreContext</code> with <code>DbSet&lt;PizzaSpecial&gt;</code></dd>
                        
                        <dt>API Controller:</dt>
                        <dd><code>SpecialsController</code> with GET endpoint at <code>/specials</code></dd>
                        
                        <dt>Seed Data:</dt>
                        <dd><code>SeedData.Initialize()</code> populates initial data</dd>
                        
                        <dt>HTTP Client:</dt>
                        <dd>Blazor component uses <code>HttpClient.GetFromJsonAsync()</code></dd>
                        
                        <dt>Database File:</dt>
                        <dd>SQLite database stored as <code>pizza.db</code></dd>
                    </dl>
                    
                    <div class="mt-3">
                        <a href="/specials" target="_blank" class="btn btn-outline-info btn-sm">
                            🔗 View JSON API (/specials)
                        </a>
                        <button class="btn btn-outline-primary btn-sm ms-2" @onclick="RefreshData">
                            🔄 Refresh Data
                        </button>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5>⚙️ Technical Details</h5>
                </div>
                <div class="card-body">
                    <ul>
                        <li><strong>Entity Framework Core</strong> - Version 9.0.0</li>
                        <li><strong>SQLite Provider</strong> - File-based database</li>
                        <li><strong>HTTP Client</strong> - For JSON API communication</li>
                        <li><strong>Async Operations</strong> - <code>OnInitializedAsync()</code></li>
                        <li><strong>Dependency Injection</strong> - Services registered in Program.cs</li>
                        <li><strong>Controller Routing</strong> - MVC API endpoints</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    @if (specials == null)
    {
        <div class="alert alert-info mt-4">
            <div class="d-flex align-items-center">
                <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                Loading pizza specials from database...
            </div>
        </div>
    }
    else if (specials.Count == 0)
    {
        <div class="alert alert-warning mt-4">
            <h4>No Data Found</h4>
            <p>The database appears to be empty. Check if the seed data was loaded correctly.</p>
        </div>
    }
    else
    {
        <div class="row mt-4">
            <div class="col-12">
                <h3>📊 Database Content (Ordered by Price - Descending)</h3>
                <p class="text-muted">Data retrieved from API endpoint: <code>GET /specials</code></p>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Pizza Name</th>
                        <th>Description</th>
                        <th>Base Price</th>
                        <th>Image URL</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var special in specials)
                    {
                        <tr>
                            <td><span class="badge bg-secondary">#@special.Id</span></td>
                            <td><strong>@special.Name</strong></td>
                            <td>@special.Description</td>
                            <td><span class="h6 text-success">@special.BasePrice.ToString("C", System.Globalization.CultureInfo.CreateSpecificCulture("en-US"))</span></td>
                            <td><small class="text-muted">@special.ImageUrl</small></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="row mt-4">
            <div class="col-md-4">
                <div class="card text-center">
                    <div class="card-body">
                        <h5 class="card-title text-primary">@specials.Count</h5>
                        <p class="card-text">Total Pizza Specials</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-center">
                    <div class="card-body">
                        <h5 class="card-title text-success">@specials.Average(s => s.BasePrice).ToString("C", System.Globalization.CultureInfo.CreateSpecificCulture("en-US"))</h5>
                        <p class="card-text">Average Price</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-center">
                    <div class="card-body">
                        <h5 class="card-title text-warning">@specials.Max(s => s.BasePrice).ToString("C", System.Globalization.CultureInfo.CreateSpecificCulture("en-US"))</h5>
                        <p class="card-text">Highest Price</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="alert alert-success mt-4">
            <h5>✅ Exercise Requirements Completed:</h5>
            <ul class="mb-0">
                <li>✓ Added Entity Framework packages (Microsoft.EntityFrameworkCore, SQLite, System.Net.Http.Json)</li>
                <li>✓ Created <code>PizzaStoreContext</code> database context</li>
                <li>✓ Added <code>SpecialsController</code> API controller with GET endpoint</li>
                <li>✓ Implemented <code>SeedData</code> to populate database</li>
                <li>✓ Updated <code>Program.cs</code> with services and database initialization</li>
                <li>✓ Modified Blazor component to use <code>HttpClient.GetFromJsonAsync()</code></li>
                <li>✓ Added controller routing with <code>MapControllerRoute</code></li>
                <li>✓ Data ordered by BasePrice descending as specified</li>
            </ul>
        </div>
    }
</div>

@code {
    private List<PizzaSpecial>? specials;

    protected override async Task OnInitializedAsync()
    {
        await LoadSpecials();
    }

    private async Task LoadSpecials()
    {
        try
        {
            // Using the same pattern as the exercise - calling the API endpoint
            specials = await HttpClient.GetFromJsonAsync<List<PizzaSpecial>>(NavigationManager.BaseUri + "specials");
        }
        catch (Exception ex)
        {
            // In a production app, you'd want proper error handling
            Console.WriteLine($"Error loading specials: {ex.Message}");
            specials = new List<PizzaSpecial>();
        }
    }

    private async Task RefreshData()
    {
        specials = null; // Show loading state
        await LoadSpecials();
    }
}