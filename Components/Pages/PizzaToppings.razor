@page "/pizza-toppings"
@using BlazingPizza.Data
@inject PizzaSalesState SalesState

<PageTitle>Pizzas and Toppings</PageTitle>

<h1>Our Latest Pizzas and Toppings</h1>

<div class="row mb-4">
    <div class="col-12">
        <div class="alert alert-success">
            <h5>🏪 AppState Demo - Sales Counter</h5>
            <p>Today, we've sold this many pizzas: <strong>@SalesState.PizzasSoldToday</strong></p>
            <button class="btn btn-primary" @onclick="IncrementSales">Buy a Pizza</button>
            <small class="d-block mt-2 text-muted">This counter persists across page loads and is visible to all components!</small>
        </div>
    </div>
</div>

@* Component Parameters Demo - exactly as shown in tutorial *@
<div class="row mb-4">
    <div class="col-md-6">
        <h3>🍕 Component Parameters Demo</h3>
        <Pizza PizzaName="Hawaiian" PizzaDescription="The one with pineapple" />
    </div>
    
    <div class="col-md-6">
        <h3>🧄 Pizza Toppings</h3>
        <PizzaToppingDisplay Topping="@(new PizzaTopping() { Name = "Chilli Sauce", Ingredients = "Three kinds of chilli." })" />
    </div>
</div>

@* Cascading Parameters Demo *@
<CascadingValue Name="DealName" Value="@dealName">>
    <div class="row">
        <div class="col-12">
            <div class="card bg-warning">
                <div class="card-header">
                    <h4>📡 Cascading Parameters Demo</h4>
                </div>
                <div class="card-body">
                    <p>The deal name "Throwback Thursday" is set here and cascades to all descendant components:</p>
                    
                    @* Any descendant component rendered here will be able to access the cascading value *@
                    <DealDisplay />
                    
                    <div class="mt-3">
                        <h5>Nested Component Hierarchy</h5>
                        <ParentComponent>
                            <ChildComponent />
                        </ParentComponent>
                    </div>
                </div>
            </div>
        </div>
    </div>
</CascadingValue>

@code {
    private string dealName = "Throwback Thursday";
    
    // AppState pattern - injected service available throughout component
    private void IncrementSales()
    {
        SalesState.PizzasSoldToday++;
    }
}

